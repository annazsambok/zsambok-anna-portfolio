<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zsámbok Anna – Sportfotó Portfólió</title>

    <style>
        body {
            background-color: #f8f8f8;
            color: #222;
            font-family: "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        header {
            text-align: center;
            padding: 40px 20px;
            background-color: #2f2f2f;
            color: #fff;
        }

        nav {
            text-align: center;
            background-color: #444;
            padding: 10px 0;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            padding: 40px;
        }

        .card {
            background-color: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            overflow: hidden;
            transition: transform 0.2s ease;
        }

        .card:hover {
            transform: scale(1.03);
        }

        .card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .card h2 {
            padding: 15px;
            font-size: 1.1rem;
            color: #333;
        }

        #contact {
            padding: 40px;
            text-align: center;
        }

        footer {
            text-align: center;
            padding: 20px;
            background-color: #2f2f2f;
            color: #fff;
        }
    </style>
</head>

<body>
    <header>
        <h1>Zsámbok Anna</h1>
        <p>Sportfotó | Kézilabda | Diákolimpia | Rendezvények | Esküvő</p>
    </header>

    <nav>
        <a href="#portfolio">Portfólió</a>
        <a href="#contact">Kapcsolat</a>
    </nav>

    <section id="portfolio" class="grid">
        <a class="card" href="#">
            <img src="https://res.cloudinary.com/dgvyhfj3x/image/upload/v1782749164/186A1384_aqhwax.jpg" alt="Kézilabda">
            <h2>Kézilabda – ÓAM‑Ózdi KC</h2>
        </a>

        <a class="card" href="#">
            <img src="https://res.cloudinary.com/dgvyhfj3x/image/upload/v1782749164/186A1384_aqhwax.jpg" alt="Diákolimpia">
            <h2>Diákolimpia országos döntők</h2>
        </a>

        <a class="card" href="#">
            <img src="https://res.cloudinary.com/dgvyhfj3x/image/upload/v1782749164/186A1384_aqhwax.jpg" alt="Rendezvények">
            <h2>Rendezvények</h2>
        </a>

        <a class="card" href="#">
            <img src="https://res.cloudinary.com/dgvyhfj3x/image/upload/v1782749164/186A1384_aqhwax.jpg" alt="Esküvő">
            <h2>Esküvő</h2>
        </a>
    </section>

    <section id="contact">
        <h2>Kapcsolat</h2>
        <p>Név: Zsámbok Anna</p>
        <p>Facebook: <a href="FB_LINK">Profilom</a></p>
        <p>Instagram: <a href="IG_LINK">Profilom</a></p>
        <p>Telefon: TELEFON</p>
        <p>Email: EMAIL</p>
    </section>

    <footer>
        <p>© 2026 Zsámbok Anna</p>
    </footer>
</body>
</html>
